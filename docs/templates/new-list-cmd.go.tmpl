package RESOURCE_PACKAGE

import (
	"context"
	"fmt"

	"github.com/Korrnals/gotr/internal/client"
	"github.com/Korrnals/gotr/internal/flags"
	"github.com/Korrnals/gotr/internal/output"
	"github.com/Korrnals/gotr/internal/ui"
	"github.com/jedib0t/go-pretty/v6/table"
	"github.com/spf13/cobra"
)

func newListCmd(clientFn GetClientFunc) *cobra.Command {
	cmd := &cobra.Command{
		Use:   "list <project-id>",
		Short: "List <resource>s for a project",
		Args:  cobra.ExactArgs(1),
		RunE: func(cmd *cobra.Command, args []string) error {
			cli := clientFn(cmd)
			ctx := cmd.Context()

			// 1. Validate input
			projectID, err := flags.ValidateRequiredID(args, 0, "project_id")
			if err != nil {
				return err
			}

			// 2. Call API (auto-paginated)
			items, err := cli.GetResources(ctx, projectID)
			if err != nil {
				return fmt.Errorf("failed to list <resource>s for project %d: %w", projectID, err)
			}

			// 3. JSON mode
			if ui.IsJSON(cmd) {
				return ui.JSON(cmd, items)
			}

			// 4. Table mode
			t := ui.NewTable(cmd)
			t.AppendHeader(table.Row{"ID", "Name", "Description"})
			for _, item := range items {
				t.AppendRow(table.Row{item.ID, item.Name, item.Description})
			}
			ui.Table(cmd, t)

			return nil
		},
	}

	output.AddFlag(cmd)
	return cmd
}
