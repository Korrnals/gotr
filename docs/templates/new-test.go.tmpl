package RESOURCE_PACKAGE

import (
	"testing"

	"github.com/Korrnals/gotr/internal/client"
	"github.com/Korrnals/gotr/internal/models/data"
	"github.com/spf13/cobra"
	"github.com/stretchr/testify/assert"
)

// mockClient returns a GetClientFunc wrapping the given mock.
func mockClient(m *client.MockClient) GetClientFunc {
	return func(cmd *cobra.Command) client.ClientInterface {
		return m
	}
}

func TestGetResource_Success(t *testing.T) {
	mock := &client.MockClient{
		// Set up mock response:
		// GetResourceFn: func(ctx context.Context, id int64) (*data.Resource, error) {
		//     return &data.Resource{ID: 1, Name: "Test"}, nil
		// },
	}

	cmd := newGetCmd(mockClient(mock))
	cmd.SetArgs([]string{"1"})

	err := cmd.Execute()
	assert.NoError(t, err)
}

func TestGetResource_InvalidID(t *testing.T) {
	mock := &client.MockClient{}
	cmd := newGetCmd(mockClient(mock))
	cmd.SetArgs([]string{"abc"})

	err := cmd.Execute()
	assert.Error(t, err)
	assert.Contains(t, err.Error(), "<resource>_id")
}

func TestGetResource_APIError(t *testing.T) {
	mock := &client.MockClient{
		// Set up mock to return error:
		// GetResourceFn: func(ctx context.Context, id int64) (*data.Resource, error) {
		//     return nil, fmt.Errorf("not found")
		// },
	}

	cmd := newGetCmd(mockClient(mock))
	cmd.SetArgs([]string{"999"})

	err := cmd.Execute()
	assert.Error(t, err)
	assert.Contains(t, err.Error(), "failed to get")
}
